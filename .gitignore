# Generated by Cargo
# will have compiled files and executables
**/target/

# These are backup files generated by rustfmt
**/*.rs.bk

# VSCode
.vscode/

# Other files + dirs
private
*.temp
*.tmp
.history
.DS_Store
.zed

# microsandbox
ignore/
build/
libkrunfw.*
libkrun.*
.menv/
Sandboxfile*

# Retype
.retype/
.claude

# Node
node_modules/
dist/

# Platform-package payloads — populated by sdk/node-ts/scripts/prepare-platform-package.mjs.
# The committed package.json stays; binaries are produced per-target in CI.
sdk/node-ts/npm/*/bin/
sdk/node-ts/npm/*/lib/
sdk/node-ts/npm/*/*.node

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
env/
venv/
.venv/
